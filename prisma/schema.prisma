// Safe Door Brasil - Prisma Schema (PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// AUTH (NextAuth.js compatible)
// ============================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  emailVerified  DateTime?
  name           String?
  image          String?
  passwordHash   String?
  role           String    @default("PARENT") // "SUPERADMIN" | "ADMIN" | "PARENT"
  schoolId       String?
  school         School?   @relation(fields: [schoolId], references: [id])
  parent         Parent?
  accounts       Account[]
  sessions       Session[]
  lgpdAccepted   Boolean   @default(false)
  lgpdAcceptedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ============================================================
// SCHOOL
// ============================================================

model School {
  id                String               @id @default(cuid())
  name              String
  cnpj              String?              @unique
  address           String?
  city              String?
  state             String?
  contactEmail      String?
  contactPhone      String?
  logoUrl           String?
  status            String               @default("ACTIVE") // "ACTIVE" | "SUSPENDED" | "TRIAL" | "CANCELLED"
  admins            User[]
  classes           Class[]
  students          Student[]
  devices           Device[]
  unrecognizedLogs  UnrecognizedFaceLog[]
  pushSubscriptions PushSubscription[]
  settings          SchoolSettings?
  invites           ClassInvite[]
  subjects          Subject[]
  subscription      Subscription?
  invoices          Invoice[]
  awsAccountId      String?
  awsAccount        AwsAccount?          @relation(fields: [awsAccountId], references: [id])
  notes             String?              @db.Text
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
}

model SchoolSettings {
  id             String   @id @default(cuid())
  schoolId       String   @unique
  school         School   @relation(fields: [schoolId], references: [id])
  entryStartTime String   @default("06:00")
  entryEndTime   String   @default("09:00")
  exitStartTime  String   @default("11:00")
  exitEndTime    String   @default("18:00")
  // Per-shift schedule overrides (JSON: { "MANHA": { entry: "07:00", entryLimit: "07:30", exit: "12:00" }, ... })
  shiftSchedules String?  @db.Text
  minConfidence  Float    @default(0.90)
  notifyOnEntry  Boolean  @default(true)
  notifyOnExit   Boolean  @default(true)
  timezone       String   @default("America/Sao_Paulo")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ============================================================
// CLASS
// ============================================================

model Class {
  id        String          @id @default(cuid())
  name      String
  grade     String?
  shift     String?         // "MANHA" | "TARDE" | "NOITE" (turno)
  schoolId  String
  school    School          @relation(fields: [schoolId], references: [id])
  students  Student[]
  invites   ClassInvite[]
  schedules ClassSchedule[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([name, schoolId])
}

// ============================================================
// CLASS INVITE (bulk parent linking)
// ============================================================

model ClassInvite {
  id        String   @id @default(cuid())
  token     String   @unique
  classId   String
  class     Class    @relation(fields: [classId], references: [id])
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  createdBy String
  expiresAt DateTime
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ============================================================
// SUBJECT (discipline/matéria)
// ============================================================

model Subject {
  id        String            @id @default(cuid())
  name      String
  color     String?           // hex color e.g. "#3B82F6"
  schoolId  String
  school    School            @relation(fields: [schoolId], references: [id])
  schedules ClassSchedule[]
  events    AttendanceEvent[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([name, schoolId])
}

// ============================================================
// CLASS SCHEDULE (timetable/grade horária)
// ============================================================

model ClassSchedule {
  id          String   @id @default(cuid())
  classId     String
  class       Class    @relation(fields: [classId], references: [id])
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id])
  dayOfWeek   Int      // 0=Dom, 1=Seg, 2=Ter, 3=Qua, 4=Qui, 5=Sex, 6=Sab
  period      Int      // 1, 2, 3... (aula/período do dia)
  startTime   String   // "08:00"
  endTime     String   // "08:50"
  teacherName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([classId, dayOfWeek, period])
  @@index([classId, dayOfWeek])
}

// ============================================================
// STUDENT
// ============================================================

model Student {
  id                String            @id @default(cuid())
  name              String
  birthDate         DateTime?
  photoUrl          String?           // profile photo URL (one of the StudentPhotos)
  faceVector        Bytes?            // Legacy: browser face-api.js embedding (128 × float32)
  faceVectorVersion Int               @default(1)
  azurePersonId     String?           // AWS Rekognition enrollment marker (stores studentId)
  isActive          Boolean           @default(true)
  recognitionEnabled Boolean          @default(true)
  notes             String?           @db.Text
  accessCode        String?           @unique // 6-char code for parent self-linking (e.g. "A3X9K2")
  classId           String
  schoolId          String
  school            School            @relation(fields: [schoolId], references: [id])
  class             Class             @relation(fields: [classId], references: [id])
  parents           StudentParent[]
  photos            StudentPhoto[]
  attendance        AttendanceEvent[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([schoolId, classId])
}

model StudentPhoto {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  url       String
  isProfile Boolean  @default(false)
  label     String?  // "Frente", "Perfil esquerdo", "Perfil direito", etc.
  createdAt DateTime @default(now())
}

// ============================================================
// PARENT / RESPONSIBLE
// ============================================================

model Parent {
  id                String            @id @default(cuid())
  userId            String            @unique
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  name              String
  phone             String?
  cpf               String?           @unique
  students          StudentParent[]
  pushSubscriptions PushSubscription[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model StudentParent {
  studentId    String
  parentId     String
  relationship String  @default("Responsável")
  isPrimary    Boolean @default(false)
  student      Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parent       Parent  @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@id([studentId, parentId])
}

// ============================================================
// ATTENDANCE EVENT
// ============================================================

model AttendanceEvent {
  id         String   @id @default(cuid())
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id])
  deviceId   String?
  device     Device?  @relation(fields: [deviceId], references: [id])
  subjectId  String?
  subject    Subject? @relation(fields: [subjectId], references: [id])
  period     Int?
  timestamp  DateTime @default(now())
  eventType  String   // "ENTRY" | "EXIT"
  photoUrl   String?
  confidence Float?
  isManual   Boolean  @default(false)
  notes      String?
  notified   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([studentId, timestamp])
  @@index([deviceId, timestamp])
  @@index([subjectId])
}

// ============================================================
// DEVICE
// ============================================================

model Device {
  id               String               @id @default(cuid())
  schoolId         String
  school           School               @relation(fields: [schoolId], references: [id])
  name             String
  description      String?
  type             String               @default("TABLET") // "TABLET" | "CAMERA_AGENT"
  status           String               @default("OFFLINE") // "ONLINE" | "OFFLINE" | "ERROR"
  apiKey           String               @unique @default(cuid())
  lastSeen         DateTime?
  lastIpAddress    String?
  firmwareVersion  String?
  attendanceEvents AttendanceEvent[]
  unrecognizedLogs UnrecognizedFaceLog[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
}

// ============================================================
// UNRECOGNIZED FACE LOG
// ============================================================

model UnrecognizedFaceLog {
  id              String   @id @default(cuid())
  schoolId        String
  school          School   @relation(fields: [schoolId], references: [id])
  deviceId        String
  device          Device   @relation(fields: [deviceId], references: [id])
  timestamp       DateTime @default(now())
  photoUrl        String
  confidenceScore Float?
  reviewed        Boolean  @default(false)
  reviewedAt      DateTime?
  reviewedById    String?
  notes           String?
  createdAt       DateTime @default(now())
}

// ============================================================
// PUSH NOTIFICATIONS
// ============================================================

model PushSubscription {
  id        String   @id @default(cuid())
  parentId  String?
  parent    Parent?  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  schoolId  String?
  school    School?  @relation(fields: [schoolId], references: [id])
  endpoint  String   @unique @db.Text
  p256dh    String   @db.Text
  auth      String   @db.Text
  userAgent String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String?
  entityId   String?
  metadata   String?  @db.Text // JSON string
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([entityType, entityId])
}

// ============================================================
// SUBSCRIPTION & BILLING (SuperAdmin)
// ============================================================

model Subscription {
  id          String    @id @default(cuid())
  schoolId    String    @unique
  school      School    @relation(fields: [schoolId], references: [id])
  plan        String    // "ESSENCIAL" | "PROFISSIONAL" | "PREMIUM"
  billing     String    @default("MONTHLY") // "MONTHLY" | "ANNUAL"
  status      String    @default("ACTIVE") // "ACTIVE" | "PAST_DUE" | "CANCELLED" | "TRIAL"
  priceMonthly Int      // valor mensal em centavos (e.g. 49700 = R$497)
  discount    Float     @default(0) // desconto percentual (e.g. 0.20 = 20%)
  trialEndsAt DateTime?
  startsAt    DateTime  @default(now())
  endsAt      DateTime?
  cancelledAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Invoice {
  id            String   @id @default(cuid())
  schoolId      String
  school        School   @relation(fields: [schoolId], references: [id])
  amount        Int      // valor em centavos
  status        String   @default("PENDING") // "PENDING" | "PAID" | "OVERDUE" | "CANCELLED"
  dueDate       DateTime
  paidAt        DateTime?
  paymentMethod String?  // "PIX" | "BOLETO" | "CARTAO"
  reference     String?  // referência externa (gateway ID, etc.)
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([schoolId, status])
  @@index([dueDate])
}

// ============================================================
// AWS ACCOUNT MANAGEMENT (SuperAdmin)
// ============================================================

model AwsAccount {
  id              String   @id @default(cuid())
  label           String   // "Principal", "Contingência 1", etc.
  accountId       String   @unique // AWS Account ID
  region          String   @default("us-east-1")
  accessKeyId     String?  // encrypted or env-referenced
  status          String   @default("ACTIVE") // "ACTIVE" | "LIMIT_NEAR" | "LIMIT_REACHED" | "DISABLED"
  maxCollections  Int      @default(100)
  usedCollections Int      @default(0)
  maxFacesPerCol  Int      @default(10000)
  monthlyBudget   Float?   // orçamento mensal USD
  currentSpend    Float    @default(0)
  lastSyncAt      DateTime?
  schools         School[]
  notes           String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================================
// PLATFORM SETTINGS (SuperAdmin)
// ============================================================

model PlatformSettings {
  id                 String   @id @default(cuid())
  defaultPlan        String   @default("ESSENCIAL")
  trialDays          Int      @default(7)
  essencialPrice     Int      @default(49700)  // centavos
  profissionalPrice  Int      @default(99700)  // centavos
  premiumPrice       Int      @default(0)      // 0 = sob consulta
  annualDiscount     Float    @default(0.20)   // 20%
  maxStudentsEssencial    Int @default(200)
  maxStudentsProfissional Int @default(500)
  maxStudentsPremium      Int @default(0) // 0 = ilimitado
  // Webhook configuration
  webhookSecret      String?  // secret to validate incoming webhooks
  paymentProvider    String   @default("MANUAL") // "MANUAL" | "STRIPE" | "ASAAS" | "MERCADOPAGO" | "PAGARME"
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ============================================================
// WEBHOOK EVENTS (Payment Gateway Integration)
// ============================================================

model WebhookEvent {
  id              String   @id @default(cuid())
  provider        String   // "STRIPE" | "ASAAS" | "MERCADOPAGO" | "PAGARME" | "MANUAL"
  externalId      String?  // ID do evento no gateway (evt_xxx, etc.)
  eventType       String   // "payment.confirmed" | "payment.overdue" | "subscription.cancelled" etc.
  status          String   @default("RECEIVED") // "RECEIVED" | "PROCESSED" | "FAILED" | "IGNORED"
  payload         String   @db.Text // JSON completo do webhook
  schoolId        String?  // escola associada (se identificada)
  subscriptionId  String?  // assinatura associada (se identificada)
  invoiceId       String?  // fatura associada (se identificada)
  errorMessage    String?  // mensagem de erro se processamento falhou
  processedAt     DateTime?
  createdAt       DateTime @default(now())

  @@index([provider, eventType])
  @@index([status])
  @@index([schoolId])
  @@index([externalId])
}
